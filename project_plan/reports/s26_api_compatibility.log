[build] cargo build --bin sqlrite
[seed-db] project_plan/reports/s26_api_compat.db
[capture-cli-help]
[capture-mcp-manifest]
[start-server] bind=127.0.0.1:8346
[capture-openapi]
[build-current-manifest]
current_commands=13
current_env_overrides=7
current_openapi_paths=6
current_mcp_tools=4
current_grpc_methods=3
[compat-assertions]
pass=True
failures=0
[s26-api-compat-suite-complete] report=project_plan/reports/s26_api_compatibility_report.json log=project_plan/reports/s26_api_compatibility.log
