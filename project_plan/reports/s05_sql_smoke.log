$ cargo run -- init --db s05_demo.db --seed-demo --profile balanced --index-mode brute_force
initialized SQLRite database
- path=s05_demo.db
- schema_version=3
- chunk_count=3
- profile=balanced
- index_mode=brute_force

$ cargo run -- sql --db s05_demo.db --execute "SELECT vec_dims(embed('agent local memory')) AS dims, bm25_score('agent memory', 'agent systems keep local memory') AS bm25, hybrid_score(0.8, 0.2, 0.75) AS hybrid;"
[
  {
    "bm25": 4.4489545822143555,
    "dims": 16,
    "hybrid": 0.6500000000000001
  }
]

$ cargo run -- sql --db s05_demo.db --execute "CREATE VECTOR INDEX IF NOT EXISTS idx_chunks_embedding_hnsw ON chunks(embedding) USING HNSW WITH (m=16, ef_construction=64);"
created vector retrieval index `idx_chunks_embedding_hnsw` on chunks(embedding) using HNSW

$ cargo run -- sql --db s05_demo.db --execute "CREATE TEXT INDEX IF NOT EXISTS idx_chunks_content_fts ON chunks(content) USING FTS5 WITH (tokenizer=unicode61);"
created text retrieval index `idx_chunks_content_fts` on chunks(content) using FTS5

$ cargo run -- sql --db s05_demo.db --execute "SELECT name, index_kind, table_name, column_name, using_engine, options_json, status FROM retrieval_index_catalog ORDER BY name;"
[
  {
    "column_name": "content",
    "index_kind": "text",
    "name": "idx_chunks_content_fts",
    "options_json": "{\"tokenizer\":\"unicode61\"}",
    "status": "active",
    "table_name": "chunks",
    "using_engine": "fts5"
  },
  {
    "column_name": "embedding",
    "index_kind": "vector",
    "name": "idx_chunks_embedding_hnsw",
    "options_json": "{\"ef_construction\":64,\"m\":16}",
    "status": "active",
    "table_name": "chunks",
    "using_engine": "hnsw"
  }
]

$ cargo run -- sql --db s05_demo.db --execute "DROP VECTOR INDEX IF EXISTS idx_chunks_embedding_hnsw;"
dropped vector retrieval index `idx_chunks_embedding_hnsw`
