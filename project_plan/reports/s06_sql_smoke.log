$ cargo run -- sql --db s06_deterministic.db --execute "SELECT id, 1.0 - cosine_distance(embedding, vector('1,0')) AS vector_score, bm25_score('same signal', content) AS text_score, hybrid_score(1.0 - cosine_distance(embedding, vector('1,0')), bm25_score('same signal', content), 0.5) AS hybrid FROM chunks ORDER BY hybrid DESC, id ASC LIMIT 2;"
